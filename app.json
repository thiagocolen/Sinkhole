{
  "expo": {
    "name": "Sinkhole",
    "slug": "sinkhole",
    "version": "0.2.0",
    "orientation": "default",
    "icon": "./assets/sinkhole-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/sinkhole-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsouza.gdrivesync",
      "buildNumber": "5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sinkhole-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tsouza.gdrivesync",
      "versionCode": 5,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "sinkhole",
    "plugins": [
      "@react-native-google-signin/google-signin",
      "./withManageExternalStorage.js",
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "b4174f64-ad5a-4de0-8888-9efe0eb06e2c"
      }
    }
  }
}